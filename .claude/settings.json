{
  "permissions": {
    "allow": [
      "Bash(**)",
      "Read(**)",
      "Write(**)"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(rm -rf *)",
      "Bash(* --version)",
      "Bash(* --help *)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    }
  },
  "enabledPlugins": {
    "vercel@claude-plugins-official": true
  }
}
